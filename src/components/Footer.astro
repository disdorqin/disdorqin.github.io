---
import { SITE } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide site-footer__inner">
    <div>
      <div>© {year} {SITE.author} · {SITE.title}</div>
      <div style="margin-top:0.3rem">{SITE.description}</div>
    </div>
    <div style="display:flex;gap:1rem;flex-wrap:wrap">
      <a href={`https://github.com/${SITE.githubUsername}`} target="_blank" rel="noopener">GitHub</a>
      <a href={`https://github.com/${SITE.githubUsername}/${SITE.githubUsername}.github.io`} target="_blank" rel="noopener">仓库</a>
      <a href="/rss.xml" target="_blank" rel="noopener">RSS</a>
      <a href="/sitemap-index.xml" target="_blank" rel="noopener">Sitemap</a>
      <a href="/guestbook/">留言板</a>
    </div>
  </div>
</footer>
