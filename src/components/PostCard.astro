---
import type { CollectionEntry } from 'astro:content';
import { formatDate, readingTime, encodeParam } from '../utils';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, category, tags, cover } = post.data;
const minutes = readingTime(post.body ?? description);
const url = `/blog/${post.id}/`;
---

<article class="post-card">
  {
    cover && (
      <a href={url} class="post-card__cover-link">
        <img class="post-card__cover" src={cover} alt={title} loading="lazy" />
      </a>
    )
  }
  <div class="post-card__body">
    <h3 class="post-card__title">
      <a href={url}>{title}</a>
    </h3>
    <div class="post-card__meta">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      <span>·</span>
      <a class="badge badge--accent" href={`/categories/${encodeParam(category)}/`}>{category}</a>
      <span>·</span>
      <span>{minutes} 分钟阅读</span>
    </div>
    <p class="post-card__desc">{description}</p>
    {
      tags.length > 0 && (
        <div class="post-card__meta" style="margin-top:0.5rem">
          {tags.map((t) => (
            <a class="badge" href={`/tags/${encodeParam(t)}/`}>
              #{t}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
