---
import type { CollectionEntry } from 'astro:content';
import { formatDate, readingTime, encodeParam } from '../utils';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, category, tags, cover } = post.data;
const minutes = readingTime(post.body ?? description);
const url = `/blog/${post.id}/`;
---

<article class="post-card">
  {
    cover && (
      <div class="post-card__cover-wrap">
        <a href={url}>
          <img class="post-card__cover" src={cover} alt={title} loading="lazy" />
        </a>
      </div>
    )
  }
  <div class="post-card__body">
    <h3 class="post-card__title">
      <a href={url}>{title}</a>
    </h3>
    <div class="post-card__meta">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      <span>·</span>
      <a href={`/categories/${encodeParam(category)}/`}>{category}</a>
      <span>·</span>
      <span>{minutes} 分钟阅读</span>
    </div>
    <p class="post-card__desc">{description}</p>
  </div>
</article>
