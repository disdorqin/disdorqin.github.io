---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="ECUST Campus OS" description="本地校园数据控制台">
  <div class="dash">
    <header class="dash-head"><div><p>ECUST / LOCAL CAMPUS OS</p><h1>校园控制台</h1></div><span id="sync-state">连接本地数据中…</span></header>

    <section class="notices panel"><div class="panel-title"><div><p>NOTICE RADAR</p><h2>教务处更新</h2></div><button id="reload">刷新数据</button></div><div id="notice-list" class="notice-list"><div class="empty">正在读取本地 MySQL 快照…</div></div></section>

    <section class="academic-grid">
      <article class="panel"><div class="panel-title"><div><p>MY GRADES</p><h2>个人成绩</h2></div><span class="tag">私有</span></div><div id="grades" class="data-table empty">尚未同步成绩。运行 <code>python live_sync.py</code> 后刷新。</div></article>
      <article class="panel"><div class="panel-title"><div><p>WEEKLY SCHEDULE</p><h2>我的课程表</h2></div><span class="tag">本周</span></div><div id="timetable" class="data-table empty">尚未同步课程表。运行 <code>python live_sync.py</code> 后刷新。</div></article>
    </section>

    <section class="agent panel"><div class="agent-copy"><p>PERSONAL RAG AGENT</p><h2>问你的校园数据</h2><span>先检索本地 MySQL，再调用模型生成答案与来源。</span></div><div class="ask-box"><textarea id="question" placeholder="例如：教务处最近更新了什么？"></textarea><button id="ask">发送 ↗</button></div><div id="answer" class="answer">等待提问。</div></section>
  </div>
</BaseLayout>

<script>
  const base='http://127.0.0.1:8787';
  const $=(id)=>document.getElementById(id);
  const esc=(s)=>String(s??'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]));
  const rows=(record)=>record?.payload?.rows||[];
  const table=(items)=>items.length?`<table>${items.map(r=>`<tr>${r.map(c=>`<td>${esc(c)}</td>`).join('')}</tr>`).join('')}</table>`:'暂无可展示数据';
  async function load(){
    try{
      const d=await fetch(base+'/api/dashboard').then(r=>r.json());
      $('sync-state').textContent=d.synced?.[0]?`已同步 · ${d.synced[0].imported_at}`:'等待首次同步';
      $('notice-list').innerHTML=d.notices?.length?d.notices.map(n=>`<a href="${esc(n.url)}" target="_blank" rel="noreferrer"><b>${esc(n.title)}</b><small>${esc(n.last_seen)}</small></a>`).join(''):'暂无教务公告';
      $('grades').innerHTML=table(rows(d.grades?.[0]));
      $('timetable').innerHTML=table(rows(d.timetable?.[0]));
    }catch(e){$('sync-state').textContent='本地 API 未启动';$('notice-list').innerHTML='<div class="empty">请启动 ECUST 后端：<code>uvicorn app:app --host 127.0.0.1 --port 8787</code></div>';}
  }
  $('reload').addEventListener('click',load);
  $('ask').addEventListener('click',async()=>{
    const q=$('question').value.trim(); if(!q)return;
    $('answer').textContent='正在检索本地数据库…';
    try{const d=await fetch(base+'/api/ask',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({question:q})}).then(r=>r.json());$('answer').innerHTML=`<strong>回答</strong><p>${esc(d.answer)}</p><small>检索来源：${d.sources?.length||0} 条本地记录</small>`}catch(e){$('answer').textContent='Agent 请求失败，请检查本地 API 与模型配置。'}
  });
  load();
</script>

<style>
.dash{max-width:1180px;margin:auto;padding:3rem 1.25rem 6rem}.dash-head{display:flex;justify-content:space-between;align-items:end;margin:1rem 0 2rem}.dash-head p,.panel-title p,.agent-copy p{font:700 .7rem var(--font-mono);letter-spacing:.14em;color:var(--accent);margin:0 0 .5rem}.dash h1{font-size:3.5rem;letter-spacing:-.08em;margin:0}.dash h2{margin:0;font-size:1.45rem;letter-spacing:-.04em}.dash-head span,.tag{font:700 .7rem var(--font-mono);color:#047857;background:#ecfdf5;padding:.4rem .7rem;border-radius:999px}.panel{background:var(--bg-elevated);border:1px solid var(--border);border-radius:18px;padding:1.4rem}.panel-title{display:flex;justify-content:space-between;align-items:start;margin-bottom:1.2rem}.panel-title button{border:0;border-radius:8px;background:var(--text);color:var(--bg);padding:.55rem .8rem;font-weight:700}.notice-list{display:grid;grid-template-columns:repeat(2,1fr);gap:.55rem}.notice-list a{display:flex;justify-content:space-between;gap:1rem;padding:.8rem;background:var(--surface);border-radius:8px;color:var(--text);font-size:.88rem}.notice-list a:hover{text-decoration:none;background:var(--accent-soft)}.notice-list small{white-space:nowrap;color:var(--text-muted)}.academic-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem}.data-table{max-height:330px;overflow:auto}.empty{color:var(--text-muted);padding:1rem 0}table{width:100%;border-collapse:collapse;font-size:.86rem}td{border-bottom:1px solid var(--border);padding:.55rem;text-align:left}.agent{margin-top:1rem;background:linear-gradient(135deg,#111827,#243b7a);color:#fff}.agent-copy p{color:#a5b4fc}.agent-copy span{color:#cbd5e1}.ask-box{display:flex;gap:.7rem;margin:1.4rem 0}.ask-box textarea{min-height:55px;flex:1;resize:vertical;border:1px solid rgba(255,255,255,.25);border-radius:10px;padding:.8rem;background:rgba(255,255,255,.08);color:#fff}.ask-box button{border:0;border-radius:10px;padding:0 1rem;background:#a5b4fc;color:#172554;font-weight:800}.answer{padding:1rem;border-radius:10px;background:rgba(255,255,255,.08);color:#dbeafe}.answer p{white-space:pre-wrap}@media(max-width:700px){.academic-grid,.notice-list{grid-template-columns:1fr}.dash-head{align-items:start;gap:1rem;flex-direction:column}.dash h1{font-size:2.5rem}}
</style>
