---
import BaseLayout from '../../layouts/BaseLayout.astro';

const modules = [
  { icon: '◈', title: '我的学业', text: '课程表、成绩、培养方案与学习进度', tone: 'blue', href: 'https://inquiry-ecust-edu-cn-s.sslvpn.ecust.edu.cn:8118/jsxsd/' },
  { icon: '⌁', title: '教务雷达', text: '公告更新、考试安排与重要通知', tone: 'violet', href: 'https://jwc-ecust-edu-cn-s.sslvpn.ecust.edu.cn:8118/' },
  { icon: '◎', title: '教师图谱', text: '教师、学院、课程与研究方向关系', tone: 'green', href: 'https://faculty-ecust-edu-cn-s.sslvpn.ecust.edu.cn:8118/' },
  { icon: '✦', title: 'AI Agent', text: '用自然语言查询你的校园数据', tone: 'orange', href: '#agent' },
];

const events = [
  { date: 'TODAY', title: '欢迎进入 ECUST Campus Twin', detail: '等待导入本地 HAR 或数据快照' },
  { date: 'DATA', title: '数据隐私模式已启用', detail: '个人数据仅保存在浏览器本地' },
  { date: 'NEXT', title: '连接三个校园数据源', detail: '教务系统 · 教务处 · 教师主页' },
];
---

<BaseLayout title="ECUST Campus Twin" description="华东理工大学个人校园数字孪生与 AI Agent">
  <div class="ecust-shell">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">ECUST / PERSONAL CAMPUS OS</p>
        <h1>你的校园，<span>变成一张图。</span></h1>
        <p class="lead">课程、成绩、公告、教师与学业轨迹，统一进入一个可搜索、可理解、只属于你的校园数字孪生。</p>
        <div class="hero-actions">
          <a class="button primary" href="#modules">进入控制台 <span>↗</span></a>
          <a class="button ghost" href="#agent">唤醒 Personal Agent</a>
        </div>
      </div>
      <div class="orbital" aria-label="Campus data visualization" role="img">
        <div class="orbit orbit-a"></div><div class="orbit orbit-b"></div><div class="orbit orbit-c"></div>
        <div class="core"><strong>ECUST</strong><small>PERSONAL OS</small></div>
        <i class="node node-a">COURSE</i><i class="node node-b">GRADE</i><i class="node node-c">NOTICE</i><i class="node node-d">FACULTY</i>
      </div>
    </section>

    <section id="modules" class="module-grid">
      {modules.map((item) => <a class={`module-card ${item.tone}`} href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}><div class="module-icon">{item.icon}</div><h2>{item.title}</h2><p>{item.text}</p><span class="arrow">→</span></a>)}
    </section>

    <section class="workspace">
      <div class="section-heading"><div><p class="eyebrow">LIVE TIMELINE</p><h2>校园事件流</h2></div><span class="status"><b></b> LOCAL MODE</span></div>
      <div class="timeline">{events.map((event) => <div class="timeline-item"><span class="date">{event.date}</span><div><h3>{event.title}</h3><p>{event.detail}</p></div></div>)}</div>
    </section>

    <section id="agent" class="agent-card">
      <div><p class="eyebrow">PERSONAL AI AGENT</p><h2>问你的校园数据。</h2><p>“我这周有哪些课？” “教务处最近更新了什么？” “我的培养方案还差哪些模块？”</p></div>
      <div class="agent-input"><span>⌕</span><span class="placeholder">输入问题，唤醒你的校园 Agent…</span><button id="agent-submit" aria-label="发送">↗</button></div>
      <small>Agent UI 已上线 · 数据连接器将在下一阶段接入 · 不上传 Cookie 与个人原始数据</small>
    </section>
  </div>
</BaseLayout>

<style>
  .ecust-shell{max-width:1120px;margin:0 auto;padding:clamp(2rem,6vw,5.5rem) 1.25rem 6rem}.hero{min-height:580px;display:grid;grid-template-columns:1.1fr .9fr;align-items:center;gap:2rem}.eyebrow{margin:0 0 1rem;color:var(--accent);font:700 .72rem/1.2 var(--font-mono);letter-spacing:.16em}.hero h1{font-size:clamp(3rem,7vw,6.6rem);line-height:.98;letter-spacing:-.08em;margin:0;max-width:700px}.hero h1 span{display:block;color:var(--accent)}.lead{max-width:560px;color:var(--text-muted);font-size:1.12rem;margin:2rem 0}.hero-actions{display:flex;gap:.8rem;flex-wrap:wrap}.button{display:inline-flex;align-items:center;gap:.6rem;border:1px solid var(--border);border-radius:999px;padding:.75rem 1.2rem;font-weight:700}.button:hover{text-decoration:none;transform:translateY(-2px)}.button.primary{background:var(--text);color:var(--bg);border-color:var(--text)}.button.ghost{color:var(--text-muted)}.orbital{height:430px;position:relative;display:grid;place-items:center}.orbit{position:absolute;border:1px solid var(--border);border-radius:50%;transform:rotate(-24deg)}.orbit-a{width:330px;height:180px}.orbit-b{width:380px;height:260px;transform:rotate(42deg)}.orbit-c{width:250px;height:380px;transform:rotate(90deg)}.core{width:132px;height:132px;border-radius:50%;display:grid;place-content:center;text-align:center;background:linear-gradient(145deg,var(--accent),#8b5cf6);color:white;box-shadow:0 20px 70px var(--accent-soft);z-index:2}.core strong{font:800 1.5rem var(--font-mono)}.core small{font-size:.55rem;letter-spacing:.12em}.node{position:absolute;font:700 .58rem var(--font-mono);letter-spacing:.08em;background:var(--bg-elevated);border:1px solid var(--border);padding:.45rem .6rem;border-radius:999px;color:var(--text-muted);font-style:normal}.node-a{top:18%;left:10%}.node-b{top:14%;right:6%}.node-c{bottom:20%;left:2%}.node-d{bottom:12%;right:9%}.module-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.module-card{position:relative;min-height:220px;padding:1.4rem;border:1px solid var(--border);border-radius:18px;background:var(--bg-elevated);overflow:hidden;transition:transform .2s,border-color .2s}.module-card:hover{transform:translateY(-5px);border-color:var(--accent)}.module-icon{font-size:2rem;margin-bottom:2.4rem}.module-card h2{font-size:1.1rem;margin:0 0 .35rem}.module-card p{color:var(--text-muted);font-size:.9rem;margin:0;line-height:1.5}.arrow{position:absolute;right:1.4rem;bottom:1.2rem;color:var(--accent);font-size:1.3rem}.violet .module-icon{color:#8b5cf6}.green .module-icon{color:#10b981}.orange .module-icon{color:#f59e0b}.workspace{margin-top:6rem}.section-heading{display:flex;justify-content:space-between;align-items:end;border-bottom:1px solid var(--border);padding-bottom:1rem}.section-heading h2{margin:0;font-size:2rem;letter-spacing:-.05em}.status{font:700 .65rem var(--font-mono);color:var(--text-muted)}.status b{display:inline-block;width:7px;height:7px;border-radius:50%;background:#10b981;margin-right:.4rem}.timeline{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:1.2rem}.timeline-item{padding:1.2rem;border-left:2px solid var(--accent);background:var(--surface)}.date{font:700 .65rem var(--font-mono);color:var(--accent)}.timeline-item h3{font-size:1rem;margin:1rem 0 .25rem}.timeline-item p{margin:0;color:var(--text-muted);font-size:.88rem}.agent-card{margin-top:6rem;padding:clamp(1.5rem,4vw,3rem);border-radius:22px;background:linear-gradient(135deg,#111827,#243b7a);color:#fff;display:grid;grid-template-columns:1fr 1.1fr;gap:2rem;align-items:center}.agent-card .eyebrow{color:#a5b4fc}.agent-card h2{font-size:2.2rem;line-height:1;margin:.2rem 0 1rem}.agent-card p{color:#cbd5e1}.agent-input{display:flex;align-items:center;gap:.7rem;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:14px;padding:.7rem 1rem}.placeholder{color:#cbd5e1;font-size:.9rem;flex:1}.agent-input button{border:0;border-radius:9px;background:#a5b4fc;color:#172554;width:34px;height:34px;font-size:1.1rem}.agent-card small{grid-column:2;color:#94a3b8;margin-top:-1.2rem}@media(max-width:800px){.hero{grid-template-columns:1fr;min-height:auto;padding:2rem 0 4rem}.orbital{height:340px;transform:scale(.8)}.module-grid{grid-template-columns:repeat(2,1fr)}.timeline,.agent-card{grid-template-columns:1fr}.agent-card small{grid-column:auto;margin:0}}@media(max-width:480px){.module-grid{grid-template-columns:1fr}.hero h1{font-size:3.4rem}}
</style>

<script>
  const input = document.querySelector('.agent-input');
  const submit = document.querySelector('#agent-submit');
  const placeholder = document.querySelector('.placeholder');
  const ask = () => {
    if (!placeholder) return;
    placeholder.textContent = 'Agent 接口尚未连接：先导入你的本地数据快照';
  };
  submit?.addEventListener('click', ask);
  input?.addEventListener('click', ask);
</script>
