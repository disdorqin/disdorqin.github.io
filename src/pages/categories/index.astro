---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getCategories } from '../../utils/posts';
import { encodeParam } from '../../utils';

const posts = await getPublishedPosts();
const categories = getCategories(posts);
---

<BaseLayout title="分类" description="按分类浏览全部文章">
  <div class="container">
    <h1 class="page-title">分类</h1>
    <p class="page-subtitle">共 {categories.length} 个分类</p>

    <div class="chip-cloud">
      {
        categories.map((c) => (
          <a class="badge badge--accent" href={`/categories/${encodeParam(c.name)}/`}>
            {c.name} <span style="opacity:.6">· {c.count}</span>
          </a>
        ))
      }
    </div>

    {
      categories.length === 0 && (
        <p style="color:var(--text-muted);margin-top:2rem">暂无分类。</p>
      )
    }
  </div>
</BaseLayout>
