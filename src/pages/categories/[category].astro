---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getCategories } from '../../utils/posts';
import { encodeParam } from '../../utils';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const categories = getCategories(posts);
  return categories.map((c) => ({
    params: { category: c.name },
    props: {
      category: c.name,
      posts: posts.filter((p) => p.data.category === c.name),
    },
  }));
}

interface Props {
  category: string;
  posts: Awaited<ReturnType<typeof getPublishedPosts>>;
}
const { category, posts } = Astro.props;
---

<BaseLayout title={`分类：${category}`} description={`分类「${category}」下的全部文章`}>
  <div class="container">
    <h1 class="page-title">分类：{category}</h1>
    <p class="page-subtitle">
      <a class="badge" href="/categories/">← 全部分类</a>
      <span style="margin-left:0.5rem">共 {posts.length} 篇</span>
    </p>

    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
