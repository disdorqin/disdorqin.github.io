---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import { formatDate } from '../../utils';

// Get all posts (including drafts — shown in dev, filtered on build)
const allPosts = await getCollection('blog');
// Filter: only moments posts (by category or tags)
const moments = allPosts
  .filter((p) => p.data.category === '朋友圈归档' || p.data.tags.includes('朋友圈'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Group by year > month
type MonthGroup = { month: number; posts: typeof moments };
type YearGroup = { year: number; months: MonthGroup[] };

const groups: YearGroup[] = [];
for (const post of moments) {
  const d = post.data.pubDate;
  const y = d.toLocaleDateString('en-CA', { timeZone: 'Asia/Shanghai' }).slice(0, 4);
  const m = d.toLocaleDateString('en-CA', { timeZone: 'Asia/Shanghai' }).slice(5, 7);
  const year = Number(y);
  const month = Number(m);

  let yearGroup = groups.find((g) => g.year === year);
  if (!yearGroup) {
    yearGroup = { year, months: [] };
    groups.push(yearGroup);
  }

  let monthGroup = yearGroup.months.find((g) => g.month === month);
  if (!monthGroup) {
    monthGroup = { month, posts: [] };
    yearGroup.months.push(monthGroup);
  }

  monthGroup.posts.push(post);
}
---

<BaseLayout title="朋友圈归档" description="按时间归档的微信朋友圈">
  <div class="container">
    <h1 class="page-title">朋友圈归档</h1>
    <p class="page-subtitle">
      共 {moments.length} 条朋友圈 · 按原发布时间倒序
    </p>

    {
      groups.length === 0 && (
        <p style="color:var(--text-muted);margin-top:2rem">
          暂无朋友圈归档。
        </p>
      )
    }

    {
      groups.map((yearGroup) => (
        <section style="margin-top:2.5rem">
          <h2 style="font-size:1.4rem;margin-bottom:1rem;border-bottom:1px solid var(--border);padding-bottom:.5rem">
            {yearGroup.year}
          </h2>

          {
            yearGroup.months.map((monthGroup) => (
              <div style="margin-bottom:1.5rem">
                <h3 style="font-size:1rem;color:var(--text-muted);margin-bottom:.75rem">
                  {yearGroup.year}年{String(monthGroup.month).padStart(2, '0')}月
                </h3>

                {
                  monthGroup.posts.map((post) => (
                    <article class="moment-item">
                      <span class="moment-date">
                        {post.data.pubDate.toLocaleDateString('en-CA', { timeZone: 'Asia/Shanghai' })}
                      </span>
                      <div class="moment-body">
                        <a href={`/blog/${post.id}/`} class="moment-title">
                          {post.data.title}
                        </a>
                        <p class="moment-summary">{post.data.description}</p>
                        {post.data.cover && (
                          <img class="moment-thumb" src={post.data.cover} alt={post.data.title} loading="lazy" />
                        )}
                      </div>
                    </article>
                  ))
                }
              </div>
            ))
          }
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .moment-item {
    display: flex;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }

  .moment-date {
    flex-shrink: 0;
    width: 8rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .moment-body {
    flex: 1;
    min-width: 0;
  }

  .moment-title {
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .moment-title:hover {
    text-decoration: underline;
  }

  .moment-summary {
    margin: 0.2rem 0 0 0;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .moment-thumb {
    margin-top: 0.4rem;
    max-width: 120px;
    max-height: 120px;
    object-fit: cover;
    border-radius: 4px;
  }

  @media (max-width: 600px) {
    .moment-item {
      flex-direction: column;
      gap: 0.3rem;
    }
    .moment-date {
      width: auto;
    }
  }
</style>
