---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../config/site';
import { getPublishedPosts, getPinnedPosts, getCategories } from '../utils/posts';
import { encodeParam } from '../utils';

const allPosts = await getPublishedPosts();
const pinnedPosts = await getPinnedPosts();
const latest = allPosts.slice(0, 5);
const categories = getCategories(allPosts);
const githubUrl = `https://github.com/${SITE.githubUsername}`;
const repoUrl = `https://github.com/${SITE.githubUsername}/${SITE.githubUsername}.github.io`;
---

<BaseLayout>
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <h1 class="hero__title">{SITE.title}</h1>
      <p class="hero__subtitle">科研、电力预测、项目日志与日常记录</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/blog/">阅读博客</a>
        <a class="btn" href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a class="btn" href="/about/">关于</a>
      </div>
    </section>

    <!-- 置顶文章 -->
    {pinnedPosts.length > 0 && (
      <section class="section">
        <div class="section__head">
          <h2 class="section__title">置顶</h2>
        </div>
        {pinnedPosts.map((post) => <PostCard post={post} />)}
      </section>
    )}

    <!-- 最新文章 -->
    <section class="section">
      <div class="section__head">
        <h2 class="section__title">最新文章</h2>
        <a class="section__more" href="/blog/">全部 →</a>
      </div>
      {latest.map((post) => <PostCard post={post} />)}
    </section>

    <!-- 分类入口 -->
    <section class="section">
      <div class="section__head">
        <h2 class="section__title">分类</h2>
        <a class="section__more" href="/categories/">全部 →</a>
      </div>
      <div class="chip-cloud">
        {categories.map((c) => (
          <a class="badge badge--accent" href={`/categories/${encodeParam(c.name)}/`}>
            {c.name} · {c.count}
          </a>
        ))}
        <a class="badge" href="/tags/">浏览标签 →</a>
      </div>
    </section>
  </div>
</BaseLayout>
