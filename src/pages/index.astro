---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../config/site';
import { getPublishedPosts } from '../utils/posts';

const allPosts = await getPublishedPosts();
const latest = allPosts.slice(0, 6);
const hasMore = allPosts.length > 6;
const githubUrl = `https://github.com/${SITE.githubUsername}`;
---

<BaseLayout>
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <h1 class="hero__title">{SITE.title}</h1>
      <p class="hero__subtitle">科研、电力预测、项目日志与日常记录</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/blog/">阅读博客</a>
        <a class="btn" href={githubUrl} target="_blank" rel="noopener">GitHub</a>
        <a class="btn" href="/about/">关于</a>
      </div>
    </section>

    <!-- 文章流 -->
    <section class="section">
      <div class="section__head">
        <h2 class="section__title">最近发布</h2>
      </div>
      {latest.map((post) => <PostCard post={post} />)}
      {
        hasMore && (
          <div style="margin-top:1.2rem;text-align:right">
            <a class="btn btn--ghost" href="/blog/page/2/">下一页 →</a>
          </div>
        )
      }
    </section>
  </div>
</BaseLayout>
