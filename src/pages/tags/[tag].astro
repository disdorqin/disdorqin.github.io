---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getTags } from '../../utils/posts';
import { encodeParam } from '../../utils';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getTags(posts);
  return tags.map((t) => ({
    params: { tag: t.name },
    props: {
      tag: t.name,
      posts: posts.filter((p) => p.data.tags.includes(t.name)),
    },
  }));
}

interface Props {
  tag: string;
  posts: Awaited<ReturnType<typeof getPublishedPosts>>;
}
const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：#${tag}`} description={`标签「${tag}」下的全部文章`}>
  <div class="container">
    <h1 class="page-title">标签：#{tag}</h1>
    <p class="page-subtitle">
      <a class="badge" href="/tags/">← 全部标签</a>
      <span style="margin-left:0.5rem">共 {posts.length} 篇</span>
    </p>

    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
