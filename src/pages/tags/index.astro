---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getTags } from '../../utils/posts';
import { encodeParam } from '../../utils';

const posts = await getPublishedPosts();
const tags = getTags(posts);
---

<BaseLayout title="标签" description="按标签浏览全部文章">
  <div class="container">
    <h1 class="page-title">标签</h1>
    <p class="page-subtitle">共 {tags.length} 个标签</p>

    <div class="chip-cloud">
      {
        tags.map((t) => (
          <a class="badge" href={`/tags/${encodeParam(t.name)}/`}>
            #{t.name} <span style="opacity:.6">· {t.count}</span>
          </a>
        ))
      }
    </div>

    {
      tags.length === 0 && (
        <p style="color:var(--text-muted);margin-top:2rem">暂无标签。</p>
      )
    }
  </div>
</BaseLayout>
