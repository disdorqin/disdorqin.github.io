---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="container notfound">
    <div class="notfound__code">404</div>
    <h1 style="margin:0 0 0.5rem">页面走丢了</h1>
    <p style="color:var(--text-muted)">你访问的页面不存在，或已被移动。</p>
    <div class="hero__actions" style="justify-content:center;margin-top:1.5rem">
      <a class="btn btn--primary" href="/">返回首页</a>
      <a class="btn" href="/blog/">浏览博客</a>
    </div>
  </div>
</BaseLayout>
